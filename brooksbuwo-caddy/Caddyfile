# brooksbuwo-caddy/Caddyfile
# Wildcard cert *.bradleybrooks.net via Cloudflare DNS-01.
# Token injected as CF_API_TOKEN environment variable -- never hardcoded here.

{
    email brooksb@uwosh.edu
    # Staging endpoint used to validate the DNS-01 flow first (avoids burning Let's
    # Encrypt production rate limits on config errors). Now commented out so Caddy uses
    # the default PRODUCTION ACME endpoint (https://acme-v02.api.letsencrypt.org/directory)
    # and issues a publicly-trusted wildcard cert. Staging cert already confirmed working.
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Wildcard cert acquisition block.
# 'abort' ensures no unmatched *.bradleybrooks.net requests are served.
# Named site blocks below override this for specific hosts.
*.bradleybrooks.net {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
        # Run certmagic's DNS-01 propagation pre-check against Cloudflare's public
        # resolvers directly. The system resolver spent 24h+ negative-caching NXDOMAIN
        # for this zone (while delegation was pending), so it never sees the fresh
        # _acme-challenge TXT and the challenge times out with "waiting for record to
        # fully propagate" (last error: <nil>). Querying 1.1.1.1/1.0.0.1 bypasses that
        # stale negative cache. propagation_delay gives Cloudflare's edge time to sync.
        resolvers 1.1.1.1 1.0.0.1
        propagation_delay 30s
        # propagation_timeout -1 DISABLES certmagic's local "has the TXT propagated?"
        # self-check and submits the challenge to Let's Encrypt directly. The local check
        # was unreliable here (timed out with "last error: <nil>" even though the
        # _acme-challenge TXT resolves publicly via Cloudflare + Google DoH). Let's Encrypt
        # does its own authoritative DNS validation, which works. propagation_delay 30s
        # still gives Cloudflare's edge time to serve the record before LE checks.
        propagation_timeout -1
    }
    abort
}

# Vaultwarden (Phase 4)
vault.bradleybrooks.net {
    encode zstd gzip
    reverse_proxy vaultwarden_server_1:8089 {
        header_up X-Real-IP {remote_host}
        flush_interval -1
    }
}

# Linkwarden (Phase 5)
linkwarden.bradleybrooks.net {
    encode zstd gzip
    reverse_proxy linkwarden_app_1:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        flush_interval -1
    }
}

# OmniTools utility toolkit (Phase 6; no login wall -- D-01/D-02)
omnitools.bradleybrooks.net {
    reverse_proxy omnitools_app_1:80
}
