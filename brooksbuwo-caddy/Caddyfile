# brooksbuwo-caddy/Caddyfile
# Wildcard cert *.bradleybrooks.net via Cloudflare DNS-01.
# Token injected as CF_API_TOKEN environment variable -- never hardcoded here.

{
    email brooksb@uwosh.edu
    acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Wildcard cert acquisition block.
# 'abort' ensures no unmatched *.bradleybrooks.net requests are served.
# Named site blocks below override this for specific hosts.
*.bradleybrooks.net {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
        # Run certmagic's DNS-01 propagation pre-check against Cloudflare's public
        # resolvers directly. The system resolver spent 24h+ negative-caching NXDOMAIN
        # for this zone (while delegation was pending), so it never sees the fresh
        # _acme-challenge TXT and the challenge times out with "waiting for record to
        # fully propagate" (last error: <nil>). Querying 1.1.1.1/1.0.0.1 bypasses that
        # stale negative cache. propagation_delay gives Cloudflare's edge time to sync.
        resolvers 1.1.1.1 1.0.0.1
        propagation_delay 15s
        propagation_timeout 5m
    }
    abort
}

# Vaultwarden (Phase 4)
vault.bradleybrooks.net {
    encode zstd gzip
    reverse_proxy vaultwarden_server_1:8089 {
        header_up X-Real-IP {remote_host}
        flush_interval -1
    }
}

# Future apps: add a new named site block here and a grey-cloud A record per app.
# Example:
# linkwarden.bradleybrooks.net {
#     reverse_proxy linkwarden_web_1:3000
# }
