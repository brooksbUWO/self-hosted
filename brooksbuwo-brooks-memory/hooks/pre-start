#!/bin/bash
# hooks/pre-start -- runs before docker-compose up
# Downloads and sha256-verifies both GGUF model files on first start.
# Aborts loudly on any error or digest mismatch (set -e + explicit exit 1).
set -e

APP_DATA_DIR="${APP_DATA_DIR:-/app-data}"
MODELS_DIR="${APP_DATA_DIR}/models"
DATA_DIR="${APP_DATA_DIR}/data"

mkdir -p "$MODELS_DIR" "$DATA_DIR"
# chown may fail in some Umbrel container contexts; || true prevents aborting on permission error
chown -R 1000:1000 "$APP_DATA_DIR" 2>/dev/null || true

# ---------------------------------------------------------------------------
# bge-m3 Q8_0 embedding model (635 MB, 634553760 bytes)
# SHA256 sourced from the HuggingFace git-lfs pointer OID (authoritative):
#   https://huggingface.co/gpustack/bge-m3-GGUF/raw/main/bge-m3-Q8_0.gguf
#   -> oid sha256:950f4a8e...1167, size 634553760
# Do NOT bypass or weaken this check.
# ---------------------------------------------------------------------------
BGE_M3_FILE="$MODELS_DIR/bge-m3-Q8_0.gguf"
BGE_M3_SHA256="950f4a8e5e19477a6d3c26d2f162233c20002c601f75e4b002e3239997821167"
BGE_M3_URL="https://huggingface.co/gpustack/bge-m3-GGUF/resolve/main/bge-m3-Q8_0.gguf"

if [ ! -f "$BGE_M3_FILE" ]; then
    echo "[brooks-memory] Downloading bge-m3-Q8_0.gguf (635 MB) ..."
    curl -fL --retry 3 -o "$BGE_M3_FILE" "$BGE_M3_URL"
    echo "[brooks-memory] Download complete: $BGE_M3_FILE"
fi

ACTUAL=$(sha256sum "$BGE_M3_FILE" | cut -d' ' -f1)
if [ "$ACTUAL" != "$BGE_M3_SHA256" ]; then
    echo "ERROR: bge-m3-Q8_0.gguf sha256 mismatch" >&2
    echo "  Expected: $BGE_M3_SHA256" >&2
    echo "  Got:      $ACTUAL" >&2
    echo "  File removed. Re-run to re-download." >&2
    rm -f "$BGE_M3_FILE"
    exit 1
fi
echo "[brooks-memory] bge-m3-Q8_0.gguf sha256 OK"

# ---------------------------------------------------------------------------
# bge-reranker-v2-m3 Q4_K_M cross-encoder model (438 MB, 438376864 bytes)
# SHA256 sourced from the HuggingFace git-lfs pointer OID (authoritative):
#   https://huggingface.co/gpustack/bge-reranker-v2-m3-GGUF/raw/main/bge-reranker-v2-m3-Q4_K_M.gguf
#   -> oid sha256:e186a244...3673, size 438376864
# Do NOT bypass or weaken this check.
# ---------------------------------------------------------------------------
RERANKER_FILE="$MODELS_DIR/bge-reranker-v2-m3-Q4_K_M.gguf"
RERANKER_SHA256="e186a244ed455b4ab66ec64339ce7427a6ae13f5c0b5e544de96e50f0f8b3673"
RERANKER_URL="https://huggingface.co/gpustack/bge-reranker-v2-m3-GGUF/resolve/main/bge-reranker-v2-m3-Q4_K_M.gguf"

if [ ! -f "$RERANKER_FILE" ]; then
    echo "[brooks-memory] Downloading bge-reranker-v2-m3-Q4_K_M.gguf ..."
    curl -fL --retry 3 -o "$RERANKER_FILE" "$RERANKER_URL"
    echo "[brooks-memory] Download complete: $RERANKER_FILE"
fi

ACTUAL=$(sha256sum "$RERANKER_FILE" | cut -d' ' -f1)
if [ "$ACTUAL" != "$RERANKER_SHA256" ]; then
    echo "ERROR: bge-reranker-v2-m3-Q4_K_M.gguf sha256 mismatch" >&2
    echo "  Expected: $RERANKER_SHA256" >&2
    echo "  Got:      $ACTUAL" >&2
    echo "  File removed. Re-run to re-download." >&2
    rm -f "$RERANKER_FILE"
    exit 1
fi
echo "[brooks-memory] bge-reranker-v2-m3-Q4_K_M.gguf sha256 OK"

echo "[brooks-memory] pre-start complete"
